# Hermes Web configuration. Copy to .env to override defaults.
# By default the API key is read from ~/.hermes/.env (API_SERVER_KEY), so you
# usually do NOT need to set HERMES_API_KEY here.

# Where the Hermes API server listens:
# HERMES_API_BASE=http://127.0.0.1:8642

# Override the API key explicitly (otherwise read from HERMES_ENV_FILE):
# HERMES_API_KEY=

# Path to the Hermes env file the key is read from:
# HERMES_ENV_FILE=/home/jw/.hermes/.env

# Where this web UI / proxy listens (0.0.0.0 = reachable on the LAN):
# HERMES_WEB_HOST=0.0.0.0
# HERMES_WEB_PORT=8080

# Hermes checkout + its venv python — used by the model picker to list/switch
# models via Hermes' own code (model_admin.py). Defaults shown:
# HERMES_HOME_DIR=/home/jw/.hermes/hermes-agent
# HERMES_VENV_PY=/home/jw/.hermes/hermes-agent/venv/bin/python

# --- Docker (docker compose) ------------------------------------------------
# Copy this file to .env in the project root; compose reads it automatically.
#
# HERMES_API_BASE=http://host.docker.internal:8642
# HERMES_DATA_DIR=/home/jw/.hermes
#
# If the model picker fails inside the container (host venv vs container libc),
# run with host networking instead:
#   docker compose -f docker-compose.yml -f docker-compose.host.yml up -d
